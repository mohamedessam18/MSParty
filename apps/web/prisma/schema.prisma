generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  passwordHash String?
  name String
  avatarUrl String?
  createdAt DateTime @default(now())
  hostedParties Party[] @relation("HostedParties")
  memberships PartyMember[]
  messages ChatMessage[]
  uploads UploadedVideo[]
}
model Party {
  id String @id @default(cuid())
  hostId String
  host User @relation("HostedParties", fields: [hostId], references: [id])
  name String
  contentType String
  contentUrl String?
  currentTimestamp Float @default(0)
  isPlaying Boolean @default(false)
  createdAt DateTime @default(now())
  members PartyMember[]
  messages ChatMessage[]
  uploadedVideo UploadedVideo?
}
model PartyMember {
  id String @id @default(cuid())
  partyId String
  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role String @default("viewer")
  joinedAt DateTime @default(now())
  @@unique([partyId, userId])
}
model UploadedVideo {
  id String @id @default(cuid())
  uploaderId String
  uploader User @relation(fields: [uploaderId], references: [id])
  partyId String? @unique
  party Party? @relation(fields: [partyId], references: [id], onDelete: SetNull)
  fileUrl String
  storageKey String @unique
  duration Float?
  uploadedAt DateTime @default(now())
  cleanupAt DateTime?

  @@index([cleanupAt])
}
model ChatMessage {
  id String @id @default(cuid())
  partyId String
  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId String
  user User @relation(fields: [userId], references: [id])
  message String
  sentAt DateTime @default(now())
}
