{
  "name": "msparty",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace=@msparty/web",
    "dev:web": "npm run dev --workspace=@msparty/web",
    "dev:sync": "npm run dev --workspace=@msparty/sync-server",
    "build": "npm run build --workspaces",
    "prisma:generate": "prisma generate --schema apps/web/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/web/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.18.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
